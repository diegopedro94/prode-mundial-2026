# Supabase — local defaults from `supabase start` output.
# When deploying to Vercel, replace with the cloud project values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# api-football (api-sports.io) — used only on the server / scripts.
# Free plan: 100 req/day.
API_FOOTBALL_KEY=

# Google OAuth — only used if you run Supabase locally without docker auth UI.
# Otherwise configure these in supabase/config.toml under [auth.external.google].
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
